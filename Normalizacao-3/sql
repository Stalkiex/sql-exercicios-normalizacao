create database Stalkiex_normativos3;
use Stalkiex_normativos3;

create table Concerto (
		Cid int primary key,
        Cart varchar(50),
        CData date,
        CHora time
	);

create table Localização (
		Sid int primary key,
        SNome varchar(50),
        SLugares int
	);

create table Funcionário (
		Fid int primary key,
        FNome varchar(50),
        FPapel varchar(50)
	);

create table Espetáculo (
		Cid int,
        Sid int,
        Fid int,
        foreign key (Cid) references Concerto(Cid),
        foreign key (Sid) references Localização(Sid),
		foreign key (Fid) references Funcionário(Fid)
	);


