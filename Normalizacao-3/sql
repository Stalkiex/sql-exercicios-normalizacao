Select
c.Cid as Cid,
c.Cart as CArt,
c.CData as CData,
c.CHora as CHora,
l.Sid as Sid,
l.SNome as SNome,
l.SLugares as SLugares,
f.Fid as Fid,
f.FNome as FNome,
f.FPapel as FPapel
from Espetáculo e
join Concerto c on e.Cid= c.Cid
join Localização l on e.Sid= l.Sid
join Funcionário f on e.Fid= f.Fid;



