Select
a.Nest as Nest,
a.NomeEst as NomeEst,
a.curso as Curso,
d.Ndisc as Ndisc,
d.NomeDisc as NomeDisc,
p.CodProf as CodProf,
p.NomeProf as NomeProf,
p.CatProf as CatProf,
n.Nota as Nota
from Nota n
join Aluno a on n.Nest= a.Nest
join Disciplina d on n.Ndisc= d.Ndisc
join Professor p on n.CodProf= p.CodProf;


