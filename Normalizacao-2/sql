create database Stalkiex_normativos2;
use Stalkiex_normativos2;


create table Aluno (
    Nest int primary key,
    NomeEst varchar(50),
    Curso varchar(45)
);

create table Professor (
    CodProf int primary key,
    NomeProf varchar(50),
    CatProf varchar(20)
);


create table Disciplina (
    Ndisc int primary key,
    NomeDisc varchar(50),
    CodProf int,
    foreign key (CodProf) references Professor(CodProf)
);

create table Nota (
    Nota int,
    Ndisc int,
    Nest int,
    CodProf int,
    foreign key (Ndisc) references Disciplina(Ndisc),
    foreign key (Nest) references Aluno(Nest),
    foreign key (CodProf) references Professor(CodProf)
);

