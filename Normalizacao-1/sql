SELECT
    p.CodProj,
    p.Tipo,
    p.Descricao,
    e.CodEmp,
    e.Nome,
    e.Categoria,
    c.Salario,
    pe.DataIni,
    pe.TProj
FROM Projeto_Empregado pe
JOIN Projeto p ON pe.CodProj = p.CodProj
JOIN Empregado e ON pe.CodEmp = e.CodEmp
JOIN Categoria c ON e.Categoria = c.Categoria
ORDER BY p.CodProj, pe.DataIni;
