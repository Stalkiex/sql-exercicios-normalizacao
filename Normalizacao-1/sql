create database Stalkiex_normativos1;
use Stalkiex_normativos1;
 
 
CREATE TABLE Projeto (
  CodProj VARCHAR(10) PRIMARY KEY,
  Tipo VARCHAR(20),
  Descricao VARCHAR(50)
);
 
CREATE TABLE Empregado (
  CodEmp INT PRIMARY KEY,
  Nome VARCHAR(20),
  Categoria VARCHAR(10),
  FOREIGN KEY (Categoria) REFERENCES Categoria(Categoria)
);
 
CREATE TABLE Categoria (
  Categoria VARCHAR(10) PRIMARY KEY,
  Salario INT
);
 
CREATE TABLE Projeto_Empregado (
  CodProj VARCHAR(10),
  CodEmp INT,
  DataIni DATE,
  TProj INT,
  PRIMARY KEY (CodProj, CodEmp, DataIni),
  FOREIGN KEY (CodProj) REFERENCES Projeto(CodProj),
  FOREIGN KEY (CodEmp) REFERENCES Empregado(CodEmp)
);
 
